# ─────────────────────────────────────────────────────────────
# MeetingMetric backend — environment variables
# Copy to `.env` and fill in. Never commit the real .env.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5200
# Comma-separated allowed browser origins for CORS. Supports exact origins
# and *.vercel.app wildcards for preview deploys.
CORS_ORIGIN=http://localhost:3000
# Public URL of the frontend (used for the Teams OAuth redirect back to the app)
FRONTEND_URL=http://localhost:3000

# Auth — REQUIRED in production. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# AI scoring tier selection (priority: Claude > Transformers.js > heuristic)
# Set ANTHROPIC_API_KEY to use Claude for scoring + coaching.
ANTHROPIC_API_KEY=
# USE_ML=1 (or unset) downloads local Transformers.js models for embeddings + zero-shot.
# USE_ML=0 skips all model downloads and uses the deterministic heuristic fallback.
USE_ML=0

# Database (optional) — path to the SQLite file. Defaults to server/data/meetingmetric.db
# MEETINGMETRIC_DB=/var/data/meetingmetric.db

# Microsoft Teams integration (optional — Azure AD app registration)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:5200/api/teams/callback
