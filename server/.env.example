# Server
PORT=5200
NODE_ENV=development

# Auth (REQUIRED — generate: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-32-char-minimum-secret

# CORS
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# AI scoring (priority: Claude > Transformers.js > heuristic)
ANTHROPIC_API_KEY=
USE_ML=0

# Database
# MEETINGMETRIC_DB=/var/data/meetingmetric.db

# Demo data: 1 = force-seed an empty DB, 0 = never seed.
# Unset = auto-seed in dev when the DB is empty. Never overwrites existing data.
# SEED_DEMO=1

# Data lake (medallion: bronze/silver/gold)
# 'local' writes under server/data-lake/, 's3' writes to the bucket below.
# If s3 is selected but credentials are missing, falls back to local with a warning.
STORAGE_MODE=local
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1
S3_BUCKET_NAME=meetingmetric-data-lake

# Microsoft Teams (Azure AD app registration — see SETUP.md)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:5200/api/teams/callback

# Logging
LOG_LEVEL=info
